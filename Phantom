const TIME_PERIODS = ['1H','1D','1W','1M','YTD','ALL']

function getDaysForPeriod(period: string): number | 'max' {
  const now = new Date()
  const startOfYear = new Date(now.getFullYear(), 0, 1)
  const ytdDays = Math.ceil((now.getTime() - startOfYear.getTime()) / (1000 * 60 * 60 * 24))
  const daysMap: Record<string, number | 'max'> = {
    '1H': 0.042,
    '1D': 1,
    '1W': 7,
    '1M': 30,
    'YTD': ytdDays,
    'ALL': 'max'
  }
  return daysMap[period] || 1
}

function renderChart(prices: [number,number][], color: string) {
  if (!prices || prices.length < 2) return null
  const vals = prices.map(p => p[1])
  const min = Math.min(...vals)
  const max = Math.max(...vals)
  const range = max - min || 1
  const w = 390
  const h = 200
  const pts = prices.map((p, i) => {
    const x = (i / (prices.length - 1)) * w
    const y = h - ((p[1] - min) / range) * 180 + 10
    return `${x},${y}`
  })
  const lastX = ((prices.length - 1) / (prices.length - 1)) * w
  const lastY = h - ((vals[vals.length - 1] - min) / range) * 180 + 10
  const polyline = pts.join(' ')
  const area = `0,${h} ${pts.join(' ')} ${w},${h}`
  
  return (
    <svg viewBox={`0 0 ${w} ${h}`} style={{width:'100%',height:200,display:'block'}}>
      <defs>
        <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stopColor={color} stopOpacity="0.25"/>
          <stop offset="100%" stopColor={color} stopOpacity="0"/>
        </linearGradient>
      </defs>
      <polygon points={area} fill="url(#chartGrad)"/>
      <polyline points={polyline} fill="none" stroke={color} strokeWidth="2.5"/>
      <circle cx={lastX} cy={lastY} r="4" fill={color}/>
    </svg>
  )
}

