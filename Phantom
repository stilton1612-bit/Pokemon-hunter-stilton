// Binance symbol mapping
const BINANCE_SYMBOLS: Record<string, string> = {
  'solana': 'SOLUSDT',
  'bitcoin': 'BTCUSDT',
  'ethereum': 'ETHUSDT',
  'tether': 'USDTUSDT',
  'usd-coin': 'USDCUSDT',
  'bonk': 'BONKUSDT',
  'jupiter-exchange-solana': 'JUPUSDT',
  'dogwifcoin': 'WIFUSDT',
}

// Period to Binance interval mapping
const PERIOD_PARAMS: Record<string, {interval: string, limit: number}> = {
  '1H': { interval: '1m', limit: 60 },
  '1D': { interval: '5m', limit: 288 },
  '1W': { interval: '1h', limit: 168 },
  '1M': { interval: '4h', limit: 180 },
  'YTD': { interval: '1d', limit: Math.ceil((Date.now() - new Date(new Date().getFullYear(), 0, 1).getTime()) / (24 * 60 * 60 * 1000)) },
  'ALL': { interval: '1w', limit: 200 },
}

export async function fetchChartData(coinId: string, period: string): Promise<[number, number][]> {
  const symbol = BINANCE_SYMBOLS[coinId]
  if (!symbol || symbol.includes('USDT' + 'USDT')) {
    // stablecoin or unknown — return flat line
    return Array.from({length: 10}, (_, i) => [Date.now() - (10-i)*3600000, 1.0])
  }
  const { interval, limit } = PERIOD_PARAMS[period] || PERIOD_PARAMS['1D']
  const url = `https://api.binance.com/api/v3/klines?symbol=${symbol}&interval=${interval}&limit=${limit}`
  
  try {
    const res = await fetch(url)
    if (!res.ok) return []
    const data = await res.json()
    return data.map((k: any[]) => [k[0], parseFloat(k[4])] as [number, number])
  } catch (e) {
    console.error('Chart fetch error:', e)
    return []
  }
}


// Shared price cache for consistency across all pages
let priceCache: PricesMap | null = null
let lastFetch = 0

export async function fetchPrices(): Promise<PricesMap> {
  if (priceCache && Date.now() - lastFetch < 30000) return priceCache
  const symbols = ['SOLUSDT','BTCUSDT','ETHUSDT','BONKUSDT','JUPUSDT','WIFUSDT']
  const url = `https://api.binance.com/api/v3/ticker/24hr?symbols=${JSON.stringify(symbols)}`
  
  try {
    const res = await fetch(url)
    if (!res.ok) return FALLBACK_PRICES
    const data: any[] = await res.json()
    
    const result: PricesMap = { ...FALLBACK_PRICES }
    const symbolToId: Record<string, string> = {
      'SOLUSDT': 'solana',
      'BTCUSDT': 'bitcoin',
      'ETHUSDT': 'ethereum',
      'BONKUSDT': 'bonk',
      'JUPUSDT': 'jupiter-exchange-solana',
      'WIFUSDT': 'dogwifcoin',
    }
    
    for (const ticker of data) {
      const id = symbolToId[ticker.symbol]
      if (id) {
        result[id] = {
          usd: parseFloat(ticker.lastPrice),
          usd_24h_change: parseFloat(ticker.priceChangePercent),
          image: result[id]?.image // preserve existing image
        }
      }
    }
    
    // USDT and USDC are stablecoins, hardcode
    result['tether'] = { usd: 1.0, usd_24h_change: 0, image: result['tether']?.image }
    result['usd-coin'] = { usd: 1.0, usd_24h_change: 0, image: result['usd-coin']?.image }
    
    priceCache = result
    lastFetch = Date.now()
    return result
  } catch (e) {
    console.error('Fetch prices error:', e)
    return FALLBACK_PRICES
  }
}

export function formatPrice(price: number): string {
  if (price < 0.001) return '$' + price.toFixed(8)
  if (price < 1) return '$' + price.toFixed(4)
  if (price < 100) return '$' + price.toFixed(2)
  return '$' + price.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}

export function formatValue(value: number): string {
  if (value >= 1000000) return '$' + (value / 1000000).toFixed(2) + 'M'
  if (value >= 1000) return '$' + value.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
  return '$' + value.toFixed(2)
}

export function formatAmount(amount: number, symbol: string): string {
  if (amount >= 1000000) return (amount / 1000000).toFixed(2) + 'M ' + symbol
  if (amount >= 1000) return amount.toLocaleString('en-US', { maximumFractionDigits: 2 }) + ' ' + symbol
  if (amount < 0.01) return amount.toFixed(6) + ' ' + symbol
  return amount.toFixed(4).replace(/\.?0+$/, '') + ' ' + symbol
}
