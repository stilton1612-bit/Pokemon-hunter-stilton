'use client'
import { useState, useEffect } from 'react'
import { useRouter } from 'next/navigation'
import BottomNav from '@/components/BottomNav'
import { TOKENS } from '@/lib/coingecko'
import { getTokenAmounts, setTokenAmounts, getWalletName, setWalletName, getCoinGeckoKey, setCoinGeckoKey } from '@/lib/storage'

export default function Settings() {
  const router = useRouter()
  const [amounts, setAmounts] = useState<Record<string, string>>({})
  const [walletName, setWalletNameState] = useState('Wallet 1')
  const [apiKey, setApiKey] = useState('')
  const [saved, setSaved] = useState(false)

  useEffect(() => {
    const stored = getTokenAmounts()
    const strAmounts: Record<string, string> = {}
    TOKENS.forEach(t => { strAmounts[t.symbol] = String(stored[t.symbol] || 0) })
    setAmounts(strAmounts)
    setWalletNameState(getWalletName())
    setApiKey(getCoinGeckoKey())
  }, [])

  function handleSave() {
    const numAmounts: Record<string, number> = {}
    TOKENS.forEach(t => { numAmounts[t.symbol] = parseFloat(amounts[t.symbol]) || 0 })
    setTokenAmounts(numAmounts)
    setWalletName(walletName)
    setCoinGeckoKey(apiKey)
    setSaved(true)
    setTimeout(() => setSaved(false), 2000)
  }

  const inputStyle = {
    width: '100%', background: '#1C1C1C', border: '1px solid rgba(255,255,255,0.1)', borderRadius: 8,
    color: '#FFFFFF', fontSize: 15, padding: '10px 12px', outline: 'none',
    fontFamily: 'inherit',
  }

  const sectionHeader = {
    fontSize: 12, fontWeight: 600, color: '#AB9FF2',
    textTransform: 'uppercase' as const, letterSpacing: '1px',
    padding: '20px 16px 10px',
  }

  return (
    <div style={{ background: '#000000', minHeight: '100vh', maxWidth: 430, margin: '0 auto', paddingBottom: 100 }}>
      <div style={{ display: 'flex', alignItems: 'center', padding: '52px 16px 16px', position: 'relative' }}>
