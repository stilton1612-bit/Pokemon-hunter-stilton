          <svg width="10" height="17" viewBox="0 0 10 17" fill="none"><path d="M9 1L1 8.5L9 16" stroke="#AB9FF2" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/></svg>
          Back
        </button>
        <span style={{ position: 'absolute', left: '50%', transform: 'translateX(-50%)', fontSize: 17, fontWeight: 700, color: '#FFFFFF' }}>Settings</span>
      </div>

      {/* Wallet Name */}
      <div style={sectionHeader}>WALLET NAME</div>
      <div style={{ padding: '0 16px' }}>
        <input
          type="text"
          value={walletName}
          onChange={e => setWalletNameState(e.target.value)}
          placeholder="Wallet 1"
          style={inputStyle}
        />
      </div>

      {/* Portfolio */}
      <div style={sectionHeader}>PORTFOLIO</div>
      <div style={{ padding: '0 16px' }}>
        {TOKENS.map((token) => (
          <div key={token.symbol} style={{
            display: 'flex', alignItems: 'flex-start', gap: 12, marginBottom: 16,
          }}>
            <div style={{ position: 'relative', flexShrink: 0, marginTop: 22 }}>
              <img src={token.logo} alt={token.symbol} style={{ width: 40, height: 40, borderRadius: 20 }} />
              <div style={{
                position:'absolute', bottom:-1, right:-1,
                width:16, height:16, borderRadius:8,
                background:'#1D9BF0',
                display:'flex', alignItems:'center', justifyContent:'center',
                border: '1.5px solid #000'
              }}>
                <svg width="9" height="7" viewBox="0 0 9 7" fill="none">
                  <path d="M1 3.5L3.5 6L8 1" stroke="white" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"/>
                </svg>
              </div>
            </div>
            <div style={{ flex: 1 }}>
              <div style={{ fontSize: 13, color: '#8E8E93', marginBottom: 4 }}>{token.name} ({token.symbol})</div>
              <div style={{ fontSize: 11, color: '#8E8E93', marginBottom: 4 }}>Amount</div>
              <input
                type="number"
                value={amounts[token.symbol] || ''}
                onChange={e => setAmounts(prev => ({ ...prev, [token.symbol]: e.target.value }))}
